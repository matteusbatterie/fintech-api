# Database
DB_SERVER=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=        # Replace with a strong password
DB_NAME=FinTechDb

# Redis
CACHE_PORT=6379

# Environment
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection="Server=${DB_SERVER},${DB_PORT};Database=${DB_NAME};User Id=${DB_USER};Password=${DB_PASSWORD};TrustServerCertificate=True;"
